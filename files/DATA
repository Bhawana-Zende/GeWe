## 🚀 Quick Start (3 Steps)

### Step 1: Create the data folder
```bash
cd gewe-frontend/src
mkdir data
# Copy mockData.js into this folder
```

### Step 2: Import in your components

**Dashboard.jsx:**
```javascript
import { mockPatients, getAllPatients } from '../data/mockData';

function Dashboard() {
  const [patients, setPatients] = useState([]);
  
  useEffect(() => {
    // Option A: Use directly (instant)
    setPatients(mockPatients);
    
    // Option B: Simulate API call with delay (more realistic)
    getAllPatients().then(data => {
      setPatients(data.patients);
    });
  }, []);
  
  return (
    <div>
      {patients.map(patient => (
        <PatientCard key={patient.id} patient={patient} />
      ))}
    </div>
  );
}
```

**PatientView.jsx:**
```javascript
import { getPatientWithDetails } from '../data/mockData';
import { useParams } from 'react-router-dom';

function PatientView() {
  const { id } = useParams();
  const [patient, setPatient] = useState(null);
  
  useEffect(() => {
    getPatientWithDetails(id).then(data => {
      setPatient(data);
    });
  }, [id]);
  
  if (!patient) return <div>Loading...</div>;
  
  return (
    <div>
      <h1>{patient.name}</h1>
      {/* Display patient details */}
    </div>
  );
}
```

### Step 3: Test it works
```bash
npm run dev
# Open http://localhost:5173
# You should see 4 patients in the dashboard
```

